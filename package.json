{
  "name": "@ai-sdk-tool/parser",
  "version": "5.0.0",
  "description": "AI SDK middleware for tool call parsing",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/minpeter/ai-sdk-tool-call-middleware"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./community": {
      "types": "./dist/community.d.ts",
      "import": "./dist/community.js",
      "require": "./dist/community.cjs"
    },
    "./rxml": {
      "types": "./dist/rxml.d.ts",
      "import": "./dist/rxml.js",
      "require": "./dist/rxml.cjs"
    },
    "./rjson": {
      "types": "./dist/rjson.d.ts",
      "import": "./dist/rjson.js",
      "require": "./dist/rjson.cjs"
    },
    "./schema-coerce": {
      "types": "./dist/schema-coerce.d.ts",
      "import": "./dist/schema-coerce.js",
      "require": "./dist/schema-coerce.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsup --tsconfig tsconfig.build.json",
    "build:watch": "pnpm clean && tsup --watch --tsconfig tsconfig.build.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:biome": "biome check",
    "check:types": "tsc --noEmit",
    "check": "run-p check:*",
    "fmt:biome": "biome check --write",
    "fmt": "run-p fmt:*",
    "changeset": "changeset",
    "ci:release": "pnpm build && changeset publish",
    "ci:version": "changeset version"
  },
  "dependencies": {
    "dedent": "^1.7.2",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "4.0.0",
    "@ai-sdk/openai-compatible": "3.0.0",
    "@ai-sdk/provider": "4.0.0",
    "@ai-sdk/provider-utils": "5.0.0",
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "2.31.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "ai": "7.0.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "ultracite": "7.8.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "vite": "^7.3.2",
      "shell-quote": "^1.8.4"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
