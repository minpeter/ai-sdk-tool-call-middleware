{
  "name": "@ai-sdk-tool/parser",
  "version": "5.1.4",
  "description": "AI SDK middleware for tool call parsing",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/minpeter/ai-sdk-tool-call-middleware"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "community": [
        "./dist/community/index.d.ts"
      ],
      "rxml": [
        "./dist/rxml/index.d.ts"
      ],
      "rjson": [
        "./dist/rjson/index.d.ts"
      ],
      "schema-coerce": [
        "./dist/schema-coerce/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./community": {
      "types": "./dist/community/index.d.ts",
      "import": "./dist/community.js"
    },
    "./rxml": {
      "types": "./dist/rxml/index.d.ts",
      "import": "./dist/rxml.js"
    },
    "./rjson": {
      "types": "./dist/rjson/index.d.ts",
      "import": "./dist/rjson.js"
    },
    "./schema-coerce": {
      "types": "./dist/schema-coerce/index.d.ts",
      "import": "./dist/schema-coerce.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsdown && tsc -p tsconfig.build.json && node scripts/fix-declaration-imports.mjs",
    "build:watch": "pnpm clean && tsdown --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:package-consumers": "node scripts/test-package-consumers.mjs",
    "attw": "attw --pack . --profile esm-only",
    "check:biome": "biome check",
    "check:types": "tsc --noEmit",
    "check": "run-p check:*",
    "fmt:biome": "biome check --write",
    "fmt": "run-p fmt:*",
    "changeset": "changeset",
    "ci:release": "pnpm build && changeset publish",
    "ci:version": "changeset version"
  },
  "dependencies": {
    "dedent": "^1.7.2",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "4.0.20",
    "@ai-sdk/openai-compatible": "3.0.14",
    "@ai-sdk/provider": "4.0.3",
    "@ai-sdk/provider-utils": "5.0.12",
    "@biomejs/biome": "2.5.5",
    "@changesets/cli": "2.31.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "ai": "7.0.37",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "tsdown": "^0.22.14",
    "typescript": "7.0.2",
    "ultracite": "7.9.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1",
      "vite": "^8.1.5",
      "shell-quote": "^1.8.4",
      "js-yaml@3": "^3.15.0",
      "js-yaml@4": "^4.2.0"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
