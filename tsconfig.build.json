{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "strictNullChecks": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "tsup.config.ts",
    "vitest.config.ts",
    "src/**/__tests__/**",
    "src/**/*.test.ts"
  ]
}
